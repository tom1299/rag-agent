# GitHub personal access token with repo scope
GITHUB_TOKEN=your_token_here

# GitHub username — must be the account handle (e.g. "tom1299"), NOT an email address.
# GitHub accepts any username with a valid PAT; "x-access-token" is a safe default.
GITHUB_USERNAME=your_github_handle

# Override private repo URL if needed
# PRIVATE_REPO_URL=https://github.com/tom1299/private
